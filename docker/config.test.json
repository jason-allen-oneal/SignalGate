{
  "version": "test-0.1.0",
  "server": {
    "host": "0.0.0.0",
    "port": 8765,
    "log_level": "info",
    "router_wall_deadline_seconds": 30
  },
  "security": {
    "auth": {
      "enabled": true,
      "header": "x-signalgate-token",
      "token_env": "SIGNALGATE_TOKEN",
      "allow_health": true
    },
    "max_body_bytes": 1000000,
    "upstreams": {
      "allow_http": true,
      "allowlist": {
        "openai": ["mock-openai"],
        "gemini": ["generativelanguage.googleapis.com"]
      }
    },
    "forward_user": {
      "mode": "hash",
      "salt_env": "SIGNALGATE_USER_SALT"
    },
    "request_fields": {
      "mode": "strip_unknown"
    }
  },
  "paths": {
    "manifest_path": "/config/manifest.test.json"
  },
  "features": {
    "enable_streaming": true,
    "enable_shadow_mode": false,
    "enable_canary": false,
    "enable_two_phase_tools": false,
    "enable_auto_tuning": false,
    "enable_response_debug": false
  },
  "routing": {
    "enable_stickiness": false
  },
  "classifier": {
    "enabled": false
  },
  "upstreams": {
    "openai": {
      "base_url": "http://mock-openai:9999/v1",
      "api_key_env": "OPENAI_API_KEY",
      "default_model": "mock-model"
    },
    "gemini": {
      "api_key_env": "GEMINI_API_KEY",
      "base_url": "https://generativelanguage.googleapis.com",
      "api_version": "v1beta"
    }
  }
}
